# Authentication mode:
# - Basic: internal Better Auth login required for the app.
# - AllowUnauthenticated: public read-only home; login required for changes,
#   settings, and test page.
# - External: use only behind another auth layer (Authelia, Authentik,
#   TinyAuth, NGINX Basic auth, etc.).
AUTHENTICATION_METHOD="Basic"

# Optional login rate-limit/lockout protection (values in seconds).
AUTH_LOGIN_LOCKOUT_SECONDS="900"
AUTH_LOGIN_WINDOW_SECONDS="900"
AUTH_MAX_LOGIN_ATTEMPTS="5"

# Better Auth secret. Required and MUST be at least 32 characters long.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Public base URL of the app. This must match the URL users open in the browser.
# For the Traefik example below, use the same host as the router rule.
BETTER_AUTH_URL="https://github-release-monitor.example.com"

# One-time setup token for creating the first admin account.
# Required for initial setup and MUST be at least 32 characters long.
# Generate one with: openssl rand -base64 32
AUTH_SETUP_TOKEN=""

# Keep self-service signup disabled by default. The first admin account is
# created through the setup flow above.
AUTH_ENABLE_SIGNUP="false"

# Enable WebAuthn passkeys for passwordless login.
AUTH_ENABLE_PASSKEY="true"

# Optional social login providers.
# Callback URLs:
# - GitHub: https://github-release-monitor.example.com/api/auth/callback/github
# - Google: https://github-release-monitor.example.com/api/auth/callback/google
AUTH_GITHUB_CLIENT_ID=""
AUTH_GITHUB_CLIENT_SECRET=""
AUTH_GOOGLE_CLIENT_ID=""
AUTH_GOOGLE_CLIENT_SECRET=""

# Trust configured social providers for automatic account linking by email.
AUTH_TRUST_SOCIAL_LINKING="true"

# Set to "false" only when running direct HTTP without TLS/reverse proxy.
# The provided Traefik example terminates HTTPS, so keep this true.
HTTPS="true"

# Optional fallback for older setups using AUTH_SECRET.
# BETTER_AUTH_SECRET is preferred; AUTH_SECRET is planned for removal in 3.0.0.
# AUTH_SECRET=""

# A GitHub personal access token is not required, but strongly recommended
# to increase the API rate limit from 60 to 5000 requests per hour.
# Create one at: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=""

# Optional: Additional GitLab instances besides gitlab.com (comma-separated).
# Use hostnames only (no schema/port), e.g. gitlab.example.com.
GITLAB_ADDITIONAL_HOSTS=""

# Optional: GitLab access tokens as comma-separated host=token pairs.
# Example: gitlab.com=glpat_xxx,gitlab.example.com=glpat_yyy
GITLAB_ACCESS_TOKENS=""

# Optional: GitLab deploy tokens as comma-separated host=username:token pairs.
# Example: gitlab.example.com=gitlab+deploy-token-123:gl-dpt-xyz
GITLAB_DEPLOY_TOKENS=""

# Optional: Codeberg token for private repos (Gitea/Forgejo API).
# Typically needs read:repository.
CODEBERG_ACCESS_TOKEN=""

# --- Email (SMTP) Notification Settings ---
# These are required to send email notifications for new releases.
MAIL_HOST="smtp"
MAIL_PORT="25"
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="GitHub Release Monitor"
MAIL_TO_ADDRESS="github-release-monitor@example.com"

# --- Apprise Notification Settings ---
# These are required to send apprise notifications for new releases.
APPRISE_URL="http://apprise:8000/notify"

# Sets the application's timezone (e.g., TZ="Europe/Berlin")
TZ=""

# Locale setting: C.UTF-8 (minimal POSIX locale with UTF-8), alternatives: en_US.UTF-8, de_DE.UTF-8, etc.
LANG="C.UTF-8"

# --- Development ---
# NODE_ENV=development

# The domain used for local development if not localhost.
# This is used to configure Next.js's allowedDevOrigins.
# ALLOWED_DEV_ORIGINS="https://example.com"
